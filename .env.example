# Configuration de l'environnement local (Docker)
# Copiez ce fichier en .env et remplissez les valeurs réelles

# ── Serveur ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Base de données PostgreSQL (valeurs Docker par défaut) ───────────────────
# Laisser DATABASE_URL vide en local → docker-compose utilise DB_*
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5433
DB_NAME=smarttrip_dev
DB_USER=smarttrip_user
DB_PASSWORD=smarttrip_password

# ── Sécurité ─────────────────────────────────────────────────────────────────
# Générer avec: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=remplacer_par_un_secret_long_et_aleatoire
JWT_EXPIRE=7d

# ── API Vols — Amadeus (https://developers.amadeus.com) ──────────────────────
AMADEUS_API_KEY=votre_cle_amadeus
AMADEUS_API_SECRET=votre_secret_amadeus
AMADEUS_BASE_URL=https://test.api.amadeus.com

# ── API Complémentaire — RapidAPI ─────────────────────────────────────────────
RAPIDAPI_KEY=votre_cle_rapidapi

# ── API Météo — OpenWeatherMap (https://openweathermap.org/api) ──────────────
OPENWEATHER_API_KEY=votre_cle_openweather

# ── Email — Brevo / SMTP ──────────────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=votre_login_brevo
SMTP_PASS=votre_mot_de_passe_smtp_brevo
SMTP_FROM=votre.email@exemple.com

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*
FRONTEND_URL=*

# ── Logs ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
